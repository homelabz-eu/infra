services:
  minio:
    image: minio/minio:latest
    container_name: minio
    restart: unless-stopped
    command: server /data --console-address ":9001" --certs-dir /certs
    ports:
      - "443:9000"
      - "9001:9001"
    environment:
      MINIO_ROOT_USER: "{{ minio_root_user }}"
      MINIO_ROOT_PASSWORD: "{{ minio_root_password }}"
      MINIO_BROWSER_REDIRECT_URL: "https://{{ minio_console_domain }}:9001"
      MINIO_SERVER_URL: "https://{{ minio_domain }}"
    volumes:
      - {{ minio_data_dir }}:/data
      - {{ minio_cert_dir }}:/certs:ro
    healthcheck:
      test: ["CMD", "mc", "ready", "local", "--insecure"]
      interval: 30s
      timeout: 10s
      retries: 3
